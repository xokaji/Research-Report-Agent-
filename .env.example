# ─────────────────────────────────────────────────────────────────────────────
# Research & Report Agent — Environment Variables
# Copy this file to .env and fill in your keys. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Get free key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Better search than DuckDuckGo (free tier = 1000 searches/month)
# Get key at https://tavily.com
TAVILY_API_KEY=tvly_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Trace agent runs visually at https://smith.langchain.com (free tier)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=research-agent-v2
